{
  "name": "spectre",
  "version": "0.5.0",
  "description": "AI Development Intelligence Agent — Session-based TUI for codebase institutional memory",
  "author": "Slashpan Technologies Private Limited <sr@slashpan.com>",
  "license": "MIT",
  "homepage": "https://github.com/SlashpanOrg/spectre",
  "repository": {
    "type": "git",
    "url": "https://github.com/SlashpanOrg/spectre.git"
  },
  "bugs": {
    "url": "https://github.com/SlashpanOrg/spectre/issues",
    "email": "sr@slashpan.com"
  },
  "bin": {
    "spectre": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.tsx",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "@google/generative-ai": "^0.24.1",
    "@inkjs/ui": "^2.0.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "better-sqlite3": "^11.10.0",
    "crypto-js": "^4.2.0",
    "diff": "^7.0.0",
    "execa": "^9.5.2",
    "fast-glob": "^3.3.3",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "loglevel": "^1.9.2",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "simple-git": "^3.36.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/crypto-js": "^4.2.2",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.29",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "ai",
    "developer-tools",
    "codebase-intelligence",
    "institutional-memory",
    "session-tui",
    "open-source",
    "slashpan"
  ]
}
