{
  "name": "spectre",
  "version": "0.1.0",
  "description": "AI Development Intelligence Agent — Your codebase's institutional memory",
  "author": "Slashpan Technologies Private Limited <sp@slashpan.com>",
  "license": "MIT",
  "homepage": "https://github.com/SlashpanOrg/spectre",
  "repository": {
    "type": "git",
    "url": "https://github.com/SlashpanOrg/spectre.git"
  },
  "bugs": {
    "url": "https://github.com/SlashpanOrg/spectre/issues",
    "email": "sp@slashpan.com"
  },
  "type": "module",
  "bin": {
    "spectre": "./dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "@inkjs/ui": "^2.0.0",
    "@qdrant/js-client-rest": "^1.12.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "crypto-js": "^4.2.0",
    "figlet": "^1.8.0",
    "ink": "^5.0.1",
    "loglevel": "^1.9.2",
    "openai": "^4.77.0",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "simple-git": "^3.27.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/crypto-js": "^4.2.2",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.4",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "ai",
    "developer-tools",
    "codebase-intelligence",
    "institutional-memory",
    "cli",
    "tui",
    "open-source",
    "slashpan"
  ]
}
